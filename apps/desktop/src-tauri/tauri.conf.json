{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fuseprobe",
  "version": "0.1.0",
  "identifier": "com.goaud.fuseprobe",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Fuseprobe",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
